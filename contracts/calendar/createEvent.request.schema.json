{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/calendar/createEvent.request.json",
  "title": "CalendarCreateEventRequest",
  "description": "Request payload for calendar.createEvent action",
  "type": "object",
  "properties": {
    "calendarId": { "type": "string", "description": "Optional calendar ID to create the event in" },
    "title": { "type": "string", "description": "Event title" },
    "startDate": { "type": "string", "description": "Start date in ISO 8601 format" },
    "endDate": { "type": "string", "description": "End date in ISO 8601 format" },
    "location": { "type": "string", "description": "Event location" },
    "notes": { "type": "string", "description": "Event notes" },
    "isAllDay": { "type": "boolean", "description": "Whether the event is an all-day event" }
  },
  "required": ["title", "startDate", "endDate"],
  "additionalProperties": false
}
