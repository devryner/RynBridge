{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/calendar/getEvents.request.json",
  "title": "CalendarGetEventsRequest",
  "description": "Request payload for calendar.getEvents action",
  "type": "object",
  "properties": {
    "calendarId": { "type": "string", "description": "Optional calendar ID to filter events" },
    "from": { "type": "string", "description": "Start date in ISO 8601 format" },
    "to": { "type": "string", "description": "End date in ISO 8601 format" }
  },
  "required": ["from", "to"],
  "additionalProperties": false
}
