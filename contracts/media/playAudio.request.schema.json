{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/media/playAudio.request.json",
  "title": "MediaPlayAudioRequest",
  "description": "Request payload for media.playAudio action",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "description": "URL or file path of the audio source"
    },
    "loop": {
      "type": "boolean",
      "description": "Whether to loop playback continuously"
    },
    "volume": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Playback volume from 0.0 to 1.0"
    }
  },
  "required": ["source"],
  "additionalProperties": false
}
