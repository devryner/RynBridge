{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/payment/purchase.request.json",
  "title": "PaymentPurchaseRequest",
  "description": "Request payload for payment.purchase action",
  "type": "object",
  "properties": {
    "productId": {
      "type": "string",
      "description": "Identifier of the product to purchase"
    },
    "quantity": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of items to purchase"
    }
  },
  "required": ["productId"],
  "additionalProperties": false
}
