{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/payment/purchase.response.json",
  "title": "PaymentPurchaseResponse",
  "description": "Response payload for payment.purchase action",
  "type": "object",
  "properties": {
    "transactionId": {
      "type": "string",
      "description": "Unique identifier for the transaction"
    },
    "productId": {
      "type": "string",
      "description": "Identifier of the purchased product"
    },
    "receipt": {
      "type": "string",
      "description": "Purchase receipt data"
    }
  },
  "required": ["transactionId", "productId", "receipt"],
  "additionalProperties": false
}
