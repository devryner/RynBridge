{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/speech/getVoices.response.json",
  "title": "SpeechGetVoicesResponse",
  "description": "Response payload for speech.getVoices action",
  "type": "object",
  "properties": {
    "voices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique voice identifier"
          },
          "name": {
            "type": "string",
            "description": "Human-readable voice name"
          },
          "language": {
            "type": "string",
            "description": "BCP 47 language tag supported by this voice"
          }
        },
        "required": ["id", "name", "language"],
        "additionalProperties": false
      },
      "description": "List of available TTS voices"
    }
  },
  "required": ["voices"],
  "additionalProperties": false
}
