{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rynbridge.io/schemas/translation/detectLanguage.response.json",
  "title": "TranslationDetectLanguageResponse",
  "description": "Response payload for translation.detectLanguage action",
  "type": "object",
  "properties": {
    "language": {
      "type": "string",
      "description": "Detected language code"
    },
    "confidence": {
      "type": "number",
      "description": "Confidence score between 0.0 and 1.0"
    }
  },
  "required": ["language", "confidence"],
  "additionalProperties": false
}
