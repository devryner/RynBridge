{
  "name": "rynbridge",
  "private": true,
  "version": "0.1.0",
  "description": "Lightweight bridge framework for Web ↔ Native communication",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "docs:dev": "pnpm --filter docs start",
    "docs:build": "pnpm --filter docs build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish",
    "doctor": "node packages/cli/dist/cli.mjs doctor",
    "check:size": "node scripts/check-bundle-size.mjs",
    "check:api": "node scripts/check-api-consistency.mjs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.3.0"
  },
  "license": "MIT"
}
